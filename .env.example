# .env.example - Configurações de Ambiente do Voci Studio SaaS

# Configurações do Banco de Dados
# O PostgreSQL roda no host local via Docker. Não use o banco public para não conflitar!
# Recomendação: crie um banco 'voci_db' no contêiner 'cogep-postgres'.
DATABASE_URL=postgresql://usuario:senha@localhost:5432/voci_db

# Configurações do Redis (Celery Broker e Backend)
# O Redis do sistema está em 'localhost:6379'. 
# IMPORTANTE: Estamos usando as bases 2 e 3 para isolar os dados do Celery e não conflitar com outras aplicações do servidor.
CELERY_BROKER_URL=redis://localhost:6379/2
CELERY_RESULT_BACKEND=redis://localhost:6379/3

# Controle de GPU Opcional
# Por padrão, start_workers.sh já define CUDA_VISIBLE_DEVICES individualmente por worker.
# APPLIO_DIR=./Applio
